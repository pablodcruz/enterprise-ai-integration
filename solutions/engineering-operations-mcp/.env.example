# Copy this file to .env. The real .env is ignored by Git.
GITHUB_MODE=recorded
HOST=127.0.0.1
PORT=8100
MCP_HOST_PORT=8100
ALLOWED_REPOSITORIES=acme/engineering-sandbox
REQUEST_TIMEOUT_MS=3000

# Required only when GITHUB_MODE=github_app. Use identifiers from your own
# GitHub App installation and an absolute path outside this repository.
# GITHUB_APP_ID=
# GITHUB_INSTALLATION_ID=
# GITHUB_PRIVATE_KEY_PATH=C:/absolute/path/outside/repository/app.private-key.pem

# Current versioned GitHub REST defaults. Override the base URL only for a
# compatible GitHub Enterprise Server or a controlled test double.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2026-03-10
