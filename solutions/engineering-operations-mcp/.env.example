# Copy this file to .env. The real .env is ignored by Git.
GITHUB_MODE=recorded
HOST=127.0.0.1
PORT=8100
MCP_HOST_PORT=8100
ALLOWED_REPOSITORIES=acme/engineering-sandbox
REQUEST_TIMEOUT_MS=3000

# Required only when GITHUB_MODE=github_app. Use identifiers from your own
# GitHub App installation and an absolute path outside this repository.
# GITHUB_APP_ID=
# GITHUB_INSTALLATION_ID=
# GITHUB_PRIVATE_KEY_PATH=C:/absolute/path/outside/repository/app.private-key.pem

# Current versioned GitHub REST defaults. Override the base URL only for a
# compatible GitHub Enterprise Server or a controlled test double.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2026-03-10

# Inbound MCP authorization. "disabled" exists only for isolated recorded-mode
# learning. Hosted deployments should use "jwt" and HTTPS resource/issuer URLs.
MCP_AUTH_MODE=disabled
MCP_RESOURCE_URL=http://127.0.0.1:8100/mcp
# MCP_AUTH_ISSUER=https://auth.example.test
# MCP_AUTH_AUDIENCE=http://127.0.0.1:8100/mcp

# JWT mode requires exactly one verification source. A remote issuer normally
# uses JWKS; the public-key path supports the self-contained local exercise.
# MCP_AUTH_JWKS_URL=https://auth.example.test/.well-known/jwks.json
# MCP_AUTH_PUBLIC_KEY_PATH=.local/auth/public.pem
MCP_AUTH_CLOCK_TOLERANCE_SECONDS=5
# MCP_RESOURCE_DOCUMENTATION_URL=https://example.test/docs/engineering-operations-mcp
