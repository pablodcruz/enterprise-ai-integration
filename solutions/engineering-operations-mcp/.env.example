# Recorded mode is the only implemented profile in this first vertical slice.
GITHUB_MODE=recorded
HOST=127.0.0.1
PORT=8100
ALLOWED_REPOSITORIES=acme/engineering-sandbox
REQUEST_TIMEOUT_MS=1000

