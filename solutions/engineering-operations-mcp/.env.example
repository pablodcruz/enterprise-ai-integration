# Recorded mode is the only implemented profile through Phase 2.
GITHUB_MODE=recorded
HOST=127.0.0.1
PORT=8100
# Change only the host side of the Docker Compose port mapping when 8100 is busy.
MCP_HOST_PORT=8100
ALLOWED_REPOSITORIES=acme/engineering-sandbox
REQUEST_TIMEOUT_MS=1000

# A later phase will add a GitHub App. Never put real credentials in this file.
# GITHUB_APP_ID=
# GITHUB_INSTALLATION_ID=
# GITHUB_PRIVATE_KEY_PATH=
