{
  "name": "engineering-operations-mcp",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Authenticated, dual-mode reference implementation for Engineering Operations MCP.",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "inspect": "tsx src/inspect.ts",
    "auth:keygen": "tsx scripts/generate-dev-auth-keys.ts",
    "auth:token": "tsx scripts/mint-dev-access-token.ts",
    "start": "tsx src/index.ts",
    "start:env": "tsx --env-file=.env src/index.ts",
    "start:dist": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "jose": "6.2.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.10.13",
    "@types/supertest": "7.2.1",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
